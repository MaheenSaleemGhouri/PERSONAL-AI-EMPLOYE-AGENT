# ============================================================
# AI Employee — Silver Tier Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
#   cp .env.example .env
# ============================================================

# ── Vault ────────────────────────────────────────────────────
VAULT_PATH=./AI_Employee_Vault

# ── Gmail Watcher ────────────────────────────────────────────
# Path to your Google OAuth credentials.json
# Download from: Google Cloud Console → APIs & Services → Credentials
GMAIL_CREDS=./credentials.json

# Where to save the OAuth token (auto-generated on first run)
GMAIL_TOKEN=./token.json

# Gmail search query (what emails to pick up)
# Examples:
#   is:unread                    ← all unread
#   is:unread is:important       ← unread + starred as important
#   is:unread from:client@co.com ← from a specific sender
GMAIL_QUERY=is:unread

# How often to check Gmail (seconds). 120 = every 2 minutes
GMAIL_INTERVAL=120

# ── LinkedIn Watcher ─────────────────────────────────────────
# Directory to store the LinkedIn browser session
# Run: python watchers/linkedin_watcher.py --setup
LINKEDIN_PROFILE=./linkedin_profile

# How often to check LinkedIn and publish approved posts (seconds)
# 300 = every 5 minutes
LINKEDIN_CHECK_INTERVAL=300

# ── WhatsApp Watcher ─────────────────────────────────────────
# Directory to store the WhatsApp Web browser session
# Run: python watchers/whatsapp_watcher.py --setup
WHATSAPP_PROFILE=./whatsapp_profile

# ── Orchestrator ─────────────────────────────────────────────
# Set to true to print commands without actually running watchers
DRY_RUN=false

# ── Security ─────────────────────────────────────────────────
# Add any other API keys here (never hardcode in .py files)
# ANTHROPIC_API_KEY=sk-ant-...
