# Gmail API Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_TOKEN_PATH=./credentials/token.json

# Vault Configuration
VAULT_PATH=/absolute/path/to/AI_Employee_Vault

# Safety Flags
DRY_RUN=true
MAX_EMAILS_PER_HOUR=10
MAX_FILES_PER_HOUR=50

# Claude Code
CLAUDE_VAULT_PATH=/absolute/path/to/AI_Employee_Vault

# ─── SILVER TIER — NEW VARIABLES ───────────────────────────────────────────

# LinkedIn Credentials
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here
LINKEDIN_PROFILE_ID=your_linkedin_profile_id

# WhatsApp Session
WHATSAPP_SESSION_PATH=/secure/local/path/to/whatsapp_session
WHATSAPP_CHECK_INTERVAL=30

# MCP Server Configuration
MCP_EMAIL_SERVER_PATH=/absolute/path/to/ai_employee/mcp/email_mcp/index.js
MCP_SERVER_PORT=3001

# Scheduling
DAILY_BRIEFING_TIME=08:00
LINKEDIN_POST_DAYS=monday,wednesday,friday
LINKEDIN_POST_TIME=10:00
QUIET_HOURS_START=23:00
QUIET_HOURS_END=07:00

# Silver Rate Limits
MAX_LINKEDIN_POSTS_PER_DAY=3
MAX_WHATSAPP_ALERTS_PER_HOUR=20

# ─── GOLD TIER — NEW VARIABLES ──────────────────────────────────────────────

# Odoo Community (self-hosted local)
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USERNAME=admin
ODOO_PASSWORD=your_odoo_password
ODOO_API_KEY=your_odoo_api_key

# Facebook Graph API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_page_access_token
FACEBOOK_PAGE_ID=your_page_id

# Instagram (via Facebook Graph API)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_account_id

# Twitter/X API v2
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Weekly Audit Scheduling
WEEKLY_AUDIT_DAY=sunday
WEEKLY_AUDIT_TIME=20:00
CEO_BRIEFING_DAY=monday
CEO_BRIEFING_TIME=07:00

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_PATH=/absolute/path/to/AI_Employee_Vault/Logs

# Error Recovery
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1
WATCHDOG_CHECK_INTERVAL=60
